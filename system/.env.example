# Copy to .env and fill in for your deployment. Do NOT commit your real .env.
ENVIRONMENT=production

# Public base URL of your deployment (e.g. http://your-server-or-domain)
BACKEND_URL=http://localhost

# Frontend API base. Leave empty to use Nginx relative paths.
VITE_API_URL=

# Admin dashboard credentials (used to export collected game logs).
# Set these to strong, unique values before any public deployment.
ADMIN_USERNAME=change-me
ADMIN_PASSWORD=change-me

# Note: OpenAI API keys are NOT configured here.
# Each game room supplies its own key through the web interface at runtime.